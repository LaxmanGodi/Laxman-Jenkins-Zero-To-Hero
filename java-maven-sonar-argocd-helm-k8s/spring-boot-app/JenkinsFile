pipeline {
  agent {
    docker {
      image 'laxmangodi/maven-laxman-docker-agent:v1'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock' // mount Docker socket to access the host's Docker daemon
    }
  }
  stages {
    stage('Checkout') {
      steps {
        sh 'echo passed'
        //git branch: 'main', url: 'https://github.com/LaxmanGodi/Laxman-Jenkins-Zero-To-Hero'
      }
    }
    stage('Build and Test') {
      steps {
        sh 'ls -ltr'
        // build the project and create a JAR file
        sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn clean package'
      }
    }
stage('Diagnostics') {
    steps {
        sh '''
            echo "Checking Java..."
            java -version
            
            echo "Checking Maven..."
            mvn -version
            
            echo "Running effective-pom..."
            # Capture the exit code of the maven command
            mvn help:effective-pom > effective_pom.xml
            echo "Maven exit code: $?"
            
            echo "Searching for sonar..."
            grep -i sonar -n effective_pom.xml
            echo "Grep exit code: $?"
        '''
    }
}
    stage('Static Code Analysis') {
      environment {
        SONAR_URL = "http://172.17.0.1:9000"
      }
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn sonar:sonar -Dsonar.login=${SONAR_AUTH_TOKEN} -Dsonar.host.url=${SONAR_URL}'
        }
      }
    }
    stage('Build and Push Docker Image') {
      environment {
        // Updated to your registered Docker Hub username: laxmangodi
        DOCKER_IMAGE = "laxmangodi/ultimate-cicd:${BUILD_NUMBER}"
        REGISTRY_CREDENTIALS = credentials('docker-cred')
      }
      steps {
        script {
          // Building the image using the local Dockerfile path
          sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && docker build -t ${DOCKER_IMAGE} .'

          def dockerImage = docker.image("${DOCKER_IMAGE}")

          // Pushing to your personal Docker Hub repository
          docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
            dockerImage.push()
          }
        }
      }
    }
    stage('Update Deployment File') {
      environment {
        GIT_REPO_NAME = "Laxman-Jenkins-Zero-To-Hero"
        GIT_USER_NAME = "LaxmanGodi"
      }
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh """
            # 1. Fix the Git ownership error inside the Docker container
            git config --global --add safe.directory '*'

            # 2. Configure identity
            git config user.email "godilaxman470@gmail.com"
            git config user.name "${GIT_USER_NAME}"

            # 3. GLOBAL IMAGE UPDATE:
            # This finds any line starting with 'image:' and replaces it with YOUR image name and tag.
            # We use '|' as a delimiter so the slashes in the URL don't confuse sed.
            sed -i "s|image: .*|image: laxmangodi/ultimate-cicd:${BUILD_NUMBER}|g" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml

            # 4. Commit and Push back to GitHub
            git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
            git commit -m "Update deployment image to version ${BUILD_NUMBER} [skip ci]"

            # Push using the token for authentication
            git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:main
          """
        }
      }
    }
    stage('Cleanup') {
      steps {
        cleanWs() // Deletes the workspace before starting a new build
      }
    }
  }
}
